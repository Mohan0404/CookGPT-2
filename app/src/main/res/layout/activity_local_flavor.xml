<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Local Flavor"
            android:textColor="#1A1A1A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Detected city -->
    <TextView
        android:id="@+id/tv_current_city"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="Detecting your location…"
        android:textColor="#374151"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Manual city entry (shown when GPS unavailable) -->
    <LinearLayout
        android:id="@+id/ll_city_fallback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/et_manual_city"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:hint="Enter city (e.g. Mumbai)"
            android:inputType="textCapWords"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <Button
            android:id="@+id/btn_search_local"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/bg_green"
            android:text="Search"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- Empty/Error state -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:textColor="#6B7280"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- Recipes RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_local_recipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

</LinearLayout>