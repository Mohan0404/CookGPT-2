<?xml version="1.0" encoding="utf-8"?>
<!-- MODIFIED — Stitch MCP UI enhancement with AI Image feature -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bottom_sheet_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fast Macro Logger"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAiImage"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/bg_green"
            app:cardBackgroundColor="#F0FDF4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_sparkles"
                    app:tint="@color/bg_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Analyze food from Image (AI)"
                    android:textColor="@color/bg_green"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OR ENTER MANUALLY"
        android:gravity="center"
        android:textSize="10sp"
        android:textColor="@color/text_grey"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etFoodName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Food item (e.g. Chicken breast)"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etQuantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Quantity (grams/servings)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etCalories"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Calories"
            android:inputType="number" />

        <EditText
            android:id="@+id/etProtein"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Protein (g)"
            android:inputType="number" />

        <EditText
            android:id="@+id/etCarbs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Carbs (g)"
            android:inputType="number" />
    </LinearLayout>

    <Button
        android:id="@+id/btnAddLog"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Add to Today"
        android:textColor="@color/white"
        android:backgroundTint="@color/bg_green"
        android:textAllCaps="false" />
</LinearLayout>
