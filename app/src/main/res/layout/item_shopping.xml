<?xml version="1.0" encoding="utf-8"?>
<!-- Shopping list item — Stitch MCP: 16dp radius, 16dp padding -->
<!-- Uses LinearLayout as root (NOT CardView) to prevent FrameLayout stacking overlap -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ═══════ SECTION HEADER (category group title) ═══════ -->
    <LinearLayout
        android:id="@+id/sectionHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_leaf"
            app:tint="@color/bg_green" />

        <TextView
            android:id="@+id/tvSectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/bg_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="Produce" />
    </LinearLayout>

    <!-- ═══════ ITEM CARD ═══════ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <!-- Checkbox -->
            <CheckBox
                android:id="@+id/cbItem"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:buttonTint="@color/bg_green" />

            <!-- Item name + quantity + price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvItemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:text="Ingredient" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tvQuantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_grey"
                        android:textSize="12sp"
                        android:text="Qty: 1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ·  "
                        android:textColor="@color/text_grey"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bg_green"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:text="₹0" />
                </LinearLayout>
            </LinearLayout>

            <!-- Category chip — fixed width to prevent truncation -->
            <TextView
                android:id="@+id/chipCategory"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:textSize="10sp"
                android:textColor="@color/bg_green"
                android:background="@drawable/bg_tag_green"
                android:text="Produce"
                android:layout_marginEnd="6dp" />

            <!-- Edit icon -->
            <ImageView
                android:id="@+id/btnEditItem"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/text_grey" />

            <!-- Delete icon -->
            <ImageView
                android:id="@+id/btnDeleteItem"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/text_red" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
